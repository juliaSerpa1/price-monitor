generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Target {
  id            String   @id @default(uuid())
  name          String
  url           String
  selector      String
  thresholdPct  Float?
  createdAt     DateTime @default(now())

  prices        PriceHistory[]
}

model PriceHistory {
  id        String   @id @default(uuid())
  price     Float
  createdAt DateTime @default(now())

  targetId  String
  target    Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
}

model Embedding {
  id        String   @id @default(uuid())
  targetId  String
  vector    Unsupported("vector") // ✅ CORRETO
  content   String?   // 🔥 ADICIONE ISSO

  createdAt DateTime @default(now())
}